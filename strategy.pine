//@version=5
strategy("NQ/SPX IFVG Strategy", overlay=true, initial_capital=100000,
     default_qty_type=strategy.fixed, default_qty_value=1,
     commission_type=strategy.commission.cash_per_contract, commission_value=2.5,
     max_boxes_count=200, max_lines_count=200, max_labels_count=100)

// ─────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────
grp_fvg    = "FVG Settings"
fvg_15m    = input.bool(true,  "Show 15m FVGs",        group=grp_fvg)
fvg_1h     = input.bool(true,  "Show 1H FVGs",         group=grp_fvg)
fvg_4h     = input.bool(true,  "Show 4H FVGs",         group=grp_fvg)
fvg_1d     = input.bool(true,  "Show Daily FVGs",      group=grp_fvg)
fvg_extend = input.int(40,     "Extend Boxes (bars)",  group=grp_fvg, minval=1, maxval=500)
max_fvg    = 3  // max FVGs kept per timeframe

grp_entry  = "Entry Filters"
ema_fast   = input.int(9,   "EMA Fast",            group=grp_entry)
ema_slow   = input.int(21,  "EMA Slow",            group=grp_entry)
rsi_len    = input.int(14,  "RSI Length",          group=grp_entry)
vol_len    = input.int(20,  "Volume MA Length",    group=grp_entry)
swing_lb   = input.int(10,  "Swing Lookback (SL)", group=grp_entry, minval=3, maxval=50)

grp_rr     = "Risk / Reward"
rr_ratio   = input.float(1.0, "RR Ratio (TP)", group=grp_rr, minval=0.5, step=0.1)

// ─────────────────────────────────────────────
// COLORS
// ─────────────────────────────────────────────
// FVG — very subtle background
col_bull_fvg      = color.new(color.green, 85)
col_bear_fvg      = color.new(color.red,   85)
col_bull_fvg_bdr  = color.new(color.green, 65)
col_bear_fvg_bdr  = color.new(color.red,   65)

// IFVG — slightly more visible, solid border
col_bull_ifvg     = color.new(color.green, 70)
col_bear_ifvg     = color.new(color.red,   70)
col_bull_ifvg_bdr = color.new(color.green, 20)
col_bear_ifvg_bdr = color.new(color.red,   20)

// SL / TP
col_sl = color.new(color.red,   0)
col_tp = color.new(color.green, 0)

// ─────────────────────────────────────────────
// INDICATORS
// ─────────────────────────────────────────────
ema9   = ta.ema(close, ema_fast)
ema21  = ta.ema(close, ema_slow)
rsi    = ta.rsi(close, rsi_len)
vol_ma = ta.sma(volume, vol_len)

// ─────────────────────────────────────────────
// HTF DATA
// ─────────────────────────────────────────────
f_htf_data(tf) =>
    [h2, l2, h1, l1, h0, l0, c0, o1] = request.security(syminfo.tickerid, tf,
         [high[2], low[2], high[1], low[1], high[0], low[0], close[0], open[1]],
         lookahead=barmerge.lookahead_off)
    [h2, l2, h1, l1, h0, l0, c0, o1]

[h2_15, l2_15, h1_15, l1_15, h0_15, l0_15, c0_15, o1_15] = f_htf_data("15")
[h2_1h, l2_1h, h1_1h, l1_1h, h0_1h, l0_1h, c0_1h, o1_1h] = f_htf_data("60")
[h2_4h, l2_4h, h1_4h, l1_4h, h0_4h, l0_4h, c0_4h, o1_4h] = f_htf_data("240")
[h2_1d, l2_1d, h1_1d, l1_1d, h0_1d, l0_1d, c0_1d, o1_1d] = f_htf_data("D")

// ─────────────────────────────────────────────
// PER-TIMEFRAME FVG TRACKING ARRAYS
// Each timeframe gets its own set of 5 parallel arrays:
//   boxes, isBull, isFilled, top, bot
// Capped at max_fvg entries — oldest is removed when limit exceeded.
// ─────────────────────────────────────────────

// 15m
var box[]   b15_boxes  = array.new_box()
var bool[]  b15_bull   = array.new_bool()
var bool[]  b15_filled = array.new_bool()
var float[] b15_top    = array.new_float()
var float[] b15_bot    = array.new_float()

// 1H
var box[]   b1h_boxes  = array.new_box()
var bool[]  b1h_bull   = array.new_bool()
var bool[]  b1h_filled = array.new_bool()
var float[] b1h_top    = array.new_float()
var float[] b1h_bot    = array.new_float()

// 4H
var box[]   b4h_boxes  = array.new_box()
var bool[]  b4h_bull   = array.new_bool()
var bool[]  b4h_filled = array.new_bool()
var float[] b4h_top    = array.new_float()
var float[] b4h_bot    = array.new_float()

// Daily
var box[]   b1d_boxes  = array.new_box()
var bool[]  b1d_bull   = array.new_bool()
var bool[]  b1d_filled = array.new_bool()
var float[] b1d_top    = array.new_float()
var float[] b1d_bot    = array.new_float()

// ─────────────────────────────────────────────
// HELPERS: add FVG, trim oldest if over cap
// ─────────────────────────────────────────────
f_add(boxes, bulls, filled, tops, bots, is_bull, top, bot) =>
    // Enforce max_fvg cap: remove oldest box first
    if array.size(boxes) >= max_fvg
        old_box = array.shift(boxes)
        box.delete(old_box)
        array.shift(bulls)
        array.shift(filled)
        array.shift(tops)
        array.shift(bots)
    b = box.new(bar_index - 1, top, bar_index + fvg_extend, bot,
         border_color = is_bull ? col_bull_fvg_bdr : col_bear_fvg_bdr,
         border_width = 1,
         bgcolor      = is_bull ? col_bull_fvg : col_bear_fvg)
    array.push(boxes,  b)
    array.push(bulls,  is_bull)
    array.push(filled, false)
    array.push(tops,   top)
    array.push(bots,   bot)

// ─────────────────────────────────────────────
// FVG DETECTION — fire on first bar of new HTF candle
// ─────────────────────────────────────────────
new_15 = ta.change(time("15")) != 0
new_1h = ta.change(time("60")) != 0
new_4h = ta.change(time("240")) != 0
new_1d = ta.change(time("D"))  != 0

if fvg_15m and new_15
    if l0_15 > h2_15
        f_add(b15_boxes, b15_bull, b15_filled, b15_top, b15_bot, true,  l0_15, h2_15)
    else if h0_15 < l2_15
        f_add(b15_boxes, b15_bull, b15_filled, b15_top, b15_bot, false, l2_15, h0_15)

if fvg_1h and new_1h
    if l0_1h > h2_1h
        f_add(b1h_boxes, b1h_bull, b1h_filled, b1h_top, b1h_bot, true,  l0_1h, h2_1h)
    else if h0_1h < l2_1h
        f_add(b1h_boxes, b1h_bull, b1h_filled, b1h_top, b1h_bot, false, l2_1h, h0_1h)

if fvg_4h and new_4h
    if l0_4h > h2_4h
        f_add(b4h_boxes, b4h_bull, b4h_filled, b4h_top, b4h_bot, true,  l0_4h, h2_4h)
    else if h0_4h < l2_4h
        f_add(b4h_boxes, b4h_bull, b4h_filled, b4h_top, b4h_bot, false, l2_4h, h0_4h)

if fvg_1d and new_1d
    if l0_1d > h2_1d
        f_add(b1d_boxes, b1d_bull, b1d_filled, b1d_top, b1d_bot, true,  l0_1d, h2_1d)
    else if h0_1d < l2_1d
        f_add(b1d_boxes, b1d_bull, b1d_filled, b1d_top, b1d_bot, false, l2_1d, h0_1d)

// ─────────────────────────────────────────────
// FVG UPDATE: extend, check fill → IFVG, delete fully mitigated
// Returns true if current bar is touching an IFVG of given direction
// ─────────────────────────────────────────────
f_update(boxes, bulls, filled, tops, bots, check_bull) =>
    touching_ifvg = false
    i = 0
    while i < array.size(boxes)
        b       = array.get(boxes,  i)
        is_bull = array.get(bulls,  i)
        is_fill = array.get(filled, i)
        top_    = array.get(tops,   i)
        bot_    = array.get(bots,   i)

        // Extend right edge to follow price
        box.set_right(b, bar_index + fvg_extend)

        if not is_fill
            // Price partially enters gap → flip to IFVG
            touched = is_bull ? (low <= top_ and high >= bot_) : (high >= bot_ and low <= top_)
            if touched
                array.set(filled, i, true)
                box.set_bgcolor(b,       is_bull ? col_bull_ifvg     : col_bear_ifvg)
                box.set_border_color(b,  is_bull ? col_bull_ifvg_bdr : col_bear_ifvg_bdr)
                box.set_border_width(b,  1)
                i += 1
            else
                i += 1
        else
            // Fully mitigated = close beyond the gap entirely → delete box
            fully_done = is_bull ? close < bot_ : close > top_
            if fully_done
                box.delete(b)
                array.remove(boxes,  i)
                array.remove(bulls,  i)
                array.remove(filled, i)
                array.remove(tops,   i)
                array.remove(bots,   i)
                // do not increment i — next element shifted into position
            else
                // Check if bar is touching this IFVG (for entry signal)
                if is_bull == check_bull
                    if low <= top_ and high >= bot_
                        touching_ifvg := true
                i += 1
    touching_ifvg

touch_bull_ifvg_15 = f_update(b15_boxes, b15_bull, b15_filled, b15_top, b15_bot, true)
touch_bear_ifvg_15 = f_update(b15_boxes, b15_bull, b15_filled, b15_top, b15_bot, false)
touch_bull_ifvg_1h = f_update(b1h_boxes, b1h_bull, b1h_filled, b1h_top, b1h_bot, true)
touch_bear_ifvg_1h = f_update(b1h_boxes, b1h_bull, b1h_filled, b1h_top, b1h_bot, false)
touch_bull_ifvg_4h = f_update(b4h_boxes, b4h_bull, b4h_filled, b4h_top, b4h_bot, true)
touch_bear_ifvg_4h = f_update(b4h_boxes, b4h_bull, b4h_filled, b4h_top, b4h_bot, false)
touch_bull_ifvg_1d = f_update(b1d_boxes, b1d_bull, b1d_filled, b1d_top, b1d_bot, true)
touch_bear_ifvg_1d = f_update(b1d_boxes, b1d_bull, b1d_filled, b1d_top, b1d_bot, false)

// Any IFVG touch across all timeframes
touched_bull_ifvg = touch_bull_ifvg_15 or touch_bull_ifvg_1h or touch_bull_ifvg_4h or touch_bull_ifvg_1d
touched_bear_ifvg = touch_bear_ifvg_15 or touch_bear_ifvg_1h or touch_bear_ifvg_4h or touch_bear_ifvg_1d

// ─────────────────────────────────────────────
// ENTRY LOGIC
// ─────────────────────────────────────────────
ema_bull = ema9 > ema21
ema_bear = ema9 < ema21
rsi_bull = rsi  > 50
rsi_bear = rsi  < 50
vol_high = volume > vol_ma

// Confirmation: next candle closes in direction after IFVG touch
long_confirm  = touched_bull_ifvg[1] and close > open
short_confirm = touched_bear_ifvg[1] and close < open

long_signal  = long_confirm  and ema_bull and rsi_bull and vol_high
short_signal = short_confirm and ema_bear and rsi_bear and vol_high

// ─────────────────────────────────────────────
// SWING LEVELS
// ─────────────────────────────────────────────
swing_low  = ta.lowest(low,   swing_lb)
swing_high = ta.highest(high, swing_lb)

// ─────────────────────────────────────────────
// STRATEGY ENTRIES & EXITS
// ─────────────────────────────────────────────
if long_signal
    strategy.entry("Long", strategy.long)

if short_signal
    strategy.entry("Short", strategy.short)

strategy.exit("Long Exit",  from_entry="Long",
     stop  = swing_low,
     limit = close + (close - swing_low))

strategy.exit("Short Exit", from_entry="Short",
     stop  = swing_high,
     limit = close - (swing_high - close))

// ─────────────────────────────────────────────
// SL / TP LINES
// ─────────────────────────────────────────────
if long_signal
    sl_p = swing_low
    tp_p = close + (close - sl_p) * rr_ratio
    line.new(bar_index, sl_p, bar_index + 30, sl_p,
         color=col_sl, width=1, style=line.style_dashed)
    line.new(bar_index, tp_p, bar_index + 30, tp_p,
         color=col_tp, width=1, style=line.style_dashed)
    label.new(bar_index + 30, sl_p, "SL",
         style=label.style_label_left, size=size.tiny,
         color=color.new(color.black, 100), textcolor=col_sl)
    label.new(bar_index + 30, tp_p, "TP",
         style=label.style_label_left, size=size.tiny,
         color=color.new(color.black, 100), textcolor=col_tp)

if short_signal
    sl_p = swing_high
    tp_p = close - (sl_p - close) * rr_ratio
    line.new(bar_index, sl_p, bar_index + 30, sl_p,
         color=col_sl, width=1, style=line.style_dashed)
    line.new(bar_index, tp_p, bar_index + 30, tp_p,
         color=col_tp, width=1, style=line.style_dashed)
    label.new(bar_index + 30, sl_p, "SL",
         style=label.style_label_left, size=size.tiny,
         color=color.new(color.black, 100), textcolor=col_sl)
    label.new(bar_index + 30, tp_p, "TP",
         style=label.style_label_left, size=size.tiny,
         color=color.new(color.black, 100), textcolor=col_tp)

// ─────────────────────────────────────────────
// ENTRY ARROWS
// ─────────────────────────────────────────────
plotshape(long_signal,  title="Long",  style=shape.triangleup,
     location=location.belowbar, color=color.lime, size=size.small)
plotshape(short_signal, title="Short", style=shape.triangledown,
     location=location.abovebar, color=color.red,  size=size.small)

// ─────────────────────────────────────────────
// HTF BIAS
// ─────────────────────────────────────────────
bias_15m = c0_15 >= o1_15 ? "Bull" : "Bear"
bias_1h  = c0_1h >= o1_1h ? "Bull" : "Bear"
bias_4h  = c0_4h >= o1_4h ? "Bull" : "Bear"
bias_1d  = c0_1d >= o1_1d ? "Bull" : "Bear"

htf_count    = (bias_1h == "Bull" ? 1 : 0) + (bias_4h == "Bull" ? 1 : 0) + (bias_1d == "Bull" ? 1 : 0)
htf_bias_str = htf_count >= 2 ? "Bullish" : "Bearish"

// ─────────────────────────────────────────────
// DASHBOARD
// ─────────────────────────────────────────────
var table dash = table.new(position.top_right, 2, 7,
     bgcolor      = color.new(color.black, 60),
     border_color = color.new(color.gray,  70),
     border_width = 1,
     frame_color  = color.new(color.gray,  60),
     frame_width  = 1)

col_lbl = color.new(color.black, 60)
col_hdr = color.new(color.gray,  55)

// Header
table.cell(dash, 0, 0, "Signal",  bgcolor=col_hdr, text_color=color.new(color.white, 20), text_size=size.tiny)
table.cell(dash, 1, 0, "Status",  bgcolor=col_hdr, text_color=color.new(color.white, 20), text_size=size.tiny)

// Rows
f_row(col, row, lbl, val, is_bull) =>
    table.cell(dash, col, row, lbl,
         bgcolor    = col_lbl,
         text_color = color.new(color.gray, 20),
         text_size  = size.tiny)
    table.cell(dash, col + 1, row, val,
         bgcolor    = is_bull ? color.new(color.green, 65) : color.new(color.red, 65),
         text_color = color.white,
         text_size  = size.tiny)

trend_bull   = ema9 > ema21
bias_15_bull = bias_15m == "Bull"
bias_1h_bull = bias_1h  == "Bull"
htf_bull     = htf_bias_str == "Bullish"

f_row(0, 1, "Trend",    trend_bull   ? "Bullish" : "Bearish", trend_bull)
f_row(0, 2, "RSI",      rsi_bull     ? "Bull"    : "Bear",    rsi_bull)
f_row(0, 3, "Volume",   vol_high     ? "High"    : "Low",     vol_high)
f_row(0, 4, "15m Bias", bias_15_bull ? "Bull"    : "Bear",    bias_15_bull)
f_row(0, 5, "1H Bias",  bias_1h_bull ? "Bull"    : "Bear",    bias_1h_bull)
f_row(0, 6, "HTF Bias", htf_bull     ? "Bullish" : "Bearish", htf_bull)

// ─────────────────────────────────────────────
// ALERT CONDITIONS
// ─────────────────────────────────────────────
alertcondition(long_signal,  title="Long Signal",  message="NQ/SPX IFVG — Long signal fired")
alertcondition(short_signal, title="Short Signal", message="NQ/SPX IFVG — Short signal fired")
